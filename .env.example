# ============================================================
# Variables de entorno — Polla Mundialista FIFA 2026
# Copia este archivo como .env.local y completa los valores.
# ============================================================

# URL del proyecto Supabase (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Clave publishable / anon (Dashboard > Project Settings > API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave service_role — OPCIONAL para este MVP (las operaciones admin
# funcionan vía RLS + RPC con la sesión del administrador).
# Solo necesaria si agregas tareas server-side privilegiadas.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio (en producción: https://tu-dominio.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Pasarela de pago (opcional) ----
# Si se dejan vacías, los pagos se aprueban manualmente desde el panel admin.
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=
PAYMENT_PUBLIC_KEY=
